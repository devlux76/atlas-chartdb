{
  "name": "atlas-chartdb",
  "version": "0.1.0",
  "description": "WebAssembly-powered charting library with direct canvas rendering",
  "type": "module",
  "scripts": {
    "build:wat": "node scripts/build-wat.cjs",
    "build:ts": "tsc --noEmit && vite build",
    "build": "npm run build:wat && npm run build:ts",
    "dev": "npm run build:wat && vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wabt": "^1.0.36"
  }
}
